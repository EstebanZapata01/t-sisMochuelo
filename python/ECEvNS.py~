#!/usr/bin/env python3
# -*- coding: utf-8 -*-
import numpy as np
import matplotlib
matplotlib.use('Agg')  # Backend sin interfaz gráfica (solo guarda)
import matplotlib.pyplot as plt
import os

filepath = '/home/oem/Desktop/Unipamplona/Trabajo de grado/Códigos/datos/eventos_conus_total.dat'
data = np.loadtxt(filepath)
bin_centers = data[:, 0]
eventos_kg = data[:, 1]

exp_raw = np.array([13.27, 38.06, 29.09, 21.37, 12.27, 4.92, 4.29, 0.06, 9.15,
                    2.42, 3.92, -2.55, 0.56, -10.52, -4.29, -8.78, -0.56, -0.93, 13.52])
exp_errors_raw = np.array([22.99, 15.70, 12.64, 12.21, 11.52, 11.58, 11.27, 10.77, 11.02,
                           10.28, 10.34, 10.77, 10.34, 10.15, 10.09, 9.90, 9.84, 9.78, 9.59])
mass_total = 2.83
exp_per_kg = exp_raw / mass_total
exp_errors_per_kg = exp_errors_raw / mass_total

plt.figure(figsize=(10,6))
plt.bar(bin_centers, eventos_kg, width=9, align='center', alpha=0.7, color='blue', label='Predicción SM')
plt.errorbar(bin_centers, exp_per_kg, yerr=exp_errors_per_kg, fmt='o', color='black', capsize=3, label='Datos CONUS+')
plt.xlabel('Energía reconstruida (eV$_{ee}$)')
plt.ylabel('Excess counts [kg$^{-1}$ (10 eV)$^{-1}$]')
plt.title('CEvNS en CONUS+')
plt.legend()
plt.grid(True, alpha=0.5)
plt.xlim(150, 360)
plt.tight_layout()
output_file = 'comparacion_CONUS+.png'
plt.savefig(output_file, dpi=300)
print(f"✅ Gráfico guardado exitosamente como '{output_file}'")
print(f"📁 Ruta completa: {os.path.abspath(output_file)}")
