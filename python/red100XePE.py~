#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import numpy as np
import matplotlib.pyplot as plt
import os
import re
from io import StringIO

# =====================================================================
# CONFIGURACIÓN DE RUTAS Y PARÁMETROS
# =====================================================================
path = '/home/oem/Desktop/Unipamplona/Trabajo de grado/Códigos/datos/'
input_file = path + 'ionization_spectra_detallado.dat'
output_fig = path + 'fig_espectro_detallado_final.png'

def configurar_estetica():
    plt.style.use('seaborn-v0_8-paper')
    plt.rcParams.update({
        "font.family": "serif",
        "font.size": 11,
        "axes.labelsize": 13,
        "legend.fontsize": 10,
        "figure.dpi": 300,
        "text.usetex": False
    })

def safe_float(s):
    s = s.decode('utf-8') if isinstance(s, bytes) else s
    s = s.strip().replace('d', 'e').replace('D', 'e')
    try:
        return float(s)
    except ValueError:
        m = re.match(r'([+\-]?\d+\.?\d*)([+\-]\d+)', s)
        if m:
            return float(m.group(1) + 'E' + m.group(2))
        return 0.0

def cargar_datos_fortran(ruta):
    with open(ruta, 'r') as f:
        lineas = [l for l in f if l.strip() and not l.strip().startswith('#')]
    ncols = len(lineas[0].split())
    datos_txt = ''.join(lineas)
    return np.loadtxt(StringIO(datos_txt), converters={i: safe_float for i in range(ncols)})

def graficar_espectro():
    if not os.path.exists(input_file):
        print(f"ERROR: No se encuentra el archivo {input_file}")
        return

    data = cargar_datos_fortran(input_file)
    ncols = data.shape[1]
    
    pe    = data[:, 0]
    total = data[:, 1]  # Ahora la data pura de Fortran ya viene como debe ser.

    fig, ax = plt.subplots(figsize=(10, 3))

    ax.step(pe, total, where='mid', color='#1D3557', linewidth=2.5,
            label=r'Total CEvNS (SM)', zorder=10)
    ax.fill_between(pe, total, step="mid", alpha=0.12, color='#1D3557')

    colores = ['#E63946', '#F4A261', '#2A9D8F', '#457B9D', '#9467BD', '#8C564B']
    num_se = ncols - 2

    for i in range(num_se):
        idx = i + 2 
        y_vals = data[:, idx]
        y_vals = np.where(y_vals > 1e-35, y_vals, 1e-35)
        
        ax.step(pe, y_vals, where='mid', color=colores[i % len(colores)],
                linestyle='--', linewidth=1.4, alpha=0.85, label=f'{i+1} SE')

    for k in range(1, 9):
        x_pos = k * 27.0
        if x_pos < 225:
            ax.axvline(x_pos, color='gray', linestyle=':', linewidth=0.8, alpha=0.4)
            ax.text(x_pos, 2e-8, f'{k}$e^-$', rotation=90, fontsize=9,
                    color='gray', ha='right', va='bottom', alpha=0.8)

    ax.set_yscale('log')
    ax.set_xlim(0, 225)
    ax.set_ylim(1e-7, 1e+2) # Restaurado al rango de tasas puro
    ax.set_yticks([1e-4,1e-1])

    ax.set_xlabel(r'Visible Energy $S2$ [PE]', labelpad=12)
    ax.set_ylabel(r'Rate [Events / (5 PE $\cdot$ kg $\cdot$ day)]', labelpad=12)
    ax.set_title('RED-100 Photoelectron Spectrum: Detailed Ionization Channels', pad=18)

    ax.grid(True, which='major', ls='-', alpha=0.2, color='gray')
    ax.grid(True, which='minor', ls=':', alpha=0.05, color='gray')
    ax.legend(loc='upper right', frameon=True, ncol=2, framealpha=0.9)

    plt.tight_layout()
    plt.savefig(output_fig, bbox_inches='tight')
    print(f"✅ Éxito: Gráfica guardada en {output_fig}")
    plt.show()

if __name__ == "__main__":
    configurar_estetica()
    graficar_espectro()
