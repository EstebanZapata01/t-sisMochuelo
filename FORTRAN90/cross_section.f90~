program CEvNS_cross_section
  implicit none

  real(8), parameter :: pi = 3.141592653589793d0     
  real(8), parameter :: GF = 1.1663787d-11           
  real(8), parameter :: hbarc = 197.3269804d0        
  real(8), parameter :: fm_to_MeV = 1d0 / hbarc      

 
  integer, parameter :: Z = 54 
  integer, parameter :: N = 77 

  
  real(8), parameter :: r0 = 1.2d0  
  real(8), parameter :: s = 0.9d0   
  real(8), parameter :: R = r0 * A**(1d0/3d0)  
  real(8), parameter :: Rn = sqrt(R**2 - 5d0*s**2)

 
  real(8), parameter :: mp = 938.272d0   
  real(8), parameter :: mn = 939.565d0   
  real(8), parameter :: M = Z*mp + N*mn  

  
  real(8), parameter :: conv = 3.89379d-22

  integer, parameter :: NPTS = 200

  integer, parameter :: nE = 4
  real(8), dimension(nE), parameter :: Enu_list = (/ 10d0, 20d0, 30d0, 40d0 /)

  integer :: i, j
  real(8) :: Enu, Tmax, T, dT
  real(8) :: sigma_noFF, sigma_Helm
  character(len=200) :: filename
  integer :: unit


  do i = 1, nE
     Enu = Enu_list(i)


     Tmax = (2d0 * Enu**2) / (M + 2d0*Enu)


     dT = Tmax / real(NPTS,8)


     write(filename,'(A,F5.1,A)') '/home/oem/Desktop/Unipamplona/Trabajo de grado/Códigos/datos/spectrum_E', Enu, '.dat'

     unit = 10 + i
     open(unit=unit, file=filename, status='replace')


     write(unit,'(A)') '# T(MeV)   dSigma/dT (FF=1)   dSigma/dT (Helm) [cm^2/MeV]'


     do j = 1, NPTS
        T = dT * real(j,8)


        sigma_noFF = differential_xs(Enu, T, 1d0)

        
        sigma_Helm = differential_xs(Enu, T, Helm_formfactor(T))

        
        write(unit,'(3E20.10)') T, sigma_noFF*conv, sigma_Helm*conv
     end do

     close(unit)
  end do

contains
  
  real(8) function differential_xs(Enu, T, FF)
    implicit none
    real(8), intent(in) :: Enu, T, FF
    real(8) :: Qw, prefactor

  
    Qw = N - (1d0 - 4d0*0.231d0)*Z  

  
    prefactor = (GF**2 / (4d0*pi)) * Qw**2 * M

  
    differential_xs = prefactor * (1d0 - (M*T)/(2d0*Enu**2)) * (FF**2)
  end function differential_xs

  
  real(8) function Helm_formfactor(T)
    implicit none
    real(8), intent(in) :: T
    real(8) :: q, qRn, qr

   
    q = sqrt(2d0*M*T)

    q = q / hbarc

    if (q == 0d0) then
       Helm_formfactor = 1d0
    else
       qr = q*Rn
       qRn = (3d0*(sin(qr) - qr*cos(qr)))/(qr**3)
       Helm_formfactor = qRn * exp(- (q*s)**2 / 2d0)
    end if
  end function Helm_formfactor

end program CEvNS_cross_section
