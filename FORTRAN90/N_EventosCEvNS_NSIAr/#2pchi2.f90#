!=======================================================================
! Programa: chi2_nsi_2D
!   Calcula ฯยฒ para dos parรกmetros NSI cualesquiera (definidos por 'ipar')
!   usando los datos de CONUS+. Incluye minimizaciรณn sobre ฮฑ.
!   Genera chi2_nsi_2D.dat y un archivo de configuraciรณn nsi_config.txt
!   con las etiquetas LaTeX para los ejes (x = dV, y = uV por convenciรณn).
!=======================================================================
program chi2_nsi_2D
  use constants
  use quenching
  use xsections
  use flux
  use resolution
  implicit none

  integer :: i, j, bin, u_out, u_conf
  integer, parameter :: n_u = 1000        ! nรบmero de pasos en eps_u
  integer, parameter :: n_d = 1000        ! nรบmero de pasos en eps_d
  real(dp) :: R_exp(nbins), sigma_exp(nbins), R_unit(nbins), R_th(nbins)
  real(dp) :: Eer_vals(npts_Eer), K_matrix(npts_Eer, nbins), S_vals(npts_Eer)
  real(dp) :: eps_u, eps_d, chi2, alpha_best, sum1, sum2
  real(dp) :: eps_u_min, eps_u_max, eps_d_min, eps_d_max, deps_u, deps_d
  real(dp), parameter :: sin2th_SM = 0.23857_dp
  real(dp), parameter :: sigma_alpha = 0.169_dp
  real(dp) :: QW_SM, qw_sm_val
  real(dp) :: q_nsi_ee, q_nsi_emu, q_nsi_etau, q_eff2
  integer :: ipar   ! Selector del par de parรกmetros NSI
  character(len=200) :: outdir, filename, configfile
  character(len=50)  :: xlabel, ylabel   ! Etiquetas LaTeX (x=dV, y=uV)

  ! ================== CONFIGURACIรN DEL BARRIDO ==================
  ! Cambia ipar para elegir el par:
  !  1: ฮต_ee^uV  vs ฮต_ee^dV   (diagonal)
  !  2: ฮต_eยต^uV  vs ฮต_eยต^dV   (cambio sabor e-ยต)
  !  3: ฮต_eฯ^uV  vs ฮต_eฯ^dV   (cambio sabor e-ฯ)
  !  4: ฮต_ee^uV  vs ฮต_eยต^uV   (uV diagonal vs uV cambio)
  !  5: ฮต_ee^dV  vs ฮต_eยต^dV   (dV diagonal vs dV cambio)
  !  6: ฮต_ee^uV  vs ฮต_eยต^dV   (uV diagonal vs dV cambio)
  /home/oem/Desktop/Unipamplona/Trabajo de grado/REACTOR-CEVNS-NSI/Refs/CONUS_PhysRevD.111.075025.pdf
  ipar = 4

  ! Rangos de barrido (pueden ajustarse)
  eps_u_min = -1.0_dp
  eps_u_max =  1.0_dp
  eps_d_min = -1.0_dp
  eps_d_max =  1.0_dp
  deps_u = (eps_u_max - eps_u_min) / (n_u - 1)
  deps_d = (eps_d_max - eps_d_min) / (n_d - 1)

  outdir = '/home/oem/Desktop/Unipamplona/Trabajo de grado/Cรณdigos/datos/'
  filename = trim(outdir) // 'chi2_nsi_2D.dat'
  configfile = trim(outdir) // 'nsi_config.txt'

  ! Definir etiquetas LaTeX segรบn ipar (x=dV, y=uV)
  select case(ipar)
  case(1)
     xlabel = '$\epsilon_{ee}^{dV}$'
     ylabel = '$\epsilon_{ee}^{uV}$'
  case(2)
     xlabel = '$\epsilon_{e\mu}^{dV}$'
     ylabel = '$\epsilon_{e\mu}^{uV}$'
  case(3)
     xlabel = '$\epsilon_{e\tau}^{dV}$'
     ylabel = '$\epsilon_{e\tau}^{uV}$'
  case(4)
     xlabel = '$\epsilon_{e\mu}^{uV}$'
     ylabel = '$\epsilon_{ee}^{uV}$'
  case(5)
     xlabel = '$\epsilon_{e\mu}^{dV}$'
     ylabel = '$\epsilon_{ee}^{dV}$'
  case(6)
     xlabel = '$\epsilon_{e\mu}^{dV}$'
     ylabel = '$\epsilon_{ee}^{uV}$'
  case default
     xlabel = '$\epsilon_{x}$'
     ylabel = '$\epsilon_{y}$'
  end select

  ! Escribir archivo de configuraciรณn para Python (primera lรญnea xlabel, segunda ylabel)
  open(newunit=u_conf, file=configfile, status='replace')
  write(u_conf, '(A)') trim(xlabel)
  write(u_conf, '(A)') trim(ylabel)
  close(u_conf)

  ! Datos experimentales CONUS+
  R_exp = [13.27, 38.06, 29.09, 21.37, 12.27, 4.92, 4.29, 0.06, 9.15, &
           2.42, 3.92, -2.55, 0.56, -10.52, -4.29, -8.78, -0.56, -0.93, 13.52]
  sigma_exp = [22.99, 15.70, 12.64, 12.21, 11.52, 11.58, 11.27, 10.77, 11.02, &
               10.28, 10.34, 10.77, 10.34, 10.15, 10.09, 9.90, 9.84, 9.78, 9.59]

  ! ================== 1. Precalcular R_unit (para QV2 = 1) ==================
  call compute_resolution_matrix(npts_Eer, Eer_min, Eer_max, Eer_vals, K_matrix)
  QV2 = 1.0_dp
  do i = 1, npts_Eer
     call compute_S(Eer_vals(i), S_vals(i))
  end do
  do bin = 1, nbins
     R_unit(bin) = integral_trapecio(Eer_vals, K_matrix(:,bin), S_vals, npts_Eer)
     R_unit(bin) = R_unit(bin) * exposure_atoms_s
     R_unit(bin) = R_unit(bin) / total_mass_kg
  end do

  write(*,*) 'R_unit(1) = ', R_unit(1)

  ! Carga dรฉbil SM
  QW_SM = -N_Ge/2.0_dp + (1.0_dp - 4.0_dp*sin2th_SM)/2.0_dp * Z_Ge
  write(*,*) 'QW_SM = ', QW_SM
  write(*,*) 'Barriendo par NSI con ipar = ', ipar

  ! ================== 2. Barrido 2D con ฮฑ ==================
  open(newunit=u_out, file=filename, status='replace')
  write(u_out, '(A)') '# eps_u   eps_d   chi2'

  do i = 0, n_u-1
     eps_u = eps_u_min + i * deps_u
     do j = 0, n_d-1
        eps_d = eps_d_min + j * deps_d

        ! Inicializar contribuciones NSI
        q_nsi_ee  = 0.0_dp
        q_nsi_emu = 0.0_dp
        q_nsi_etau= 0.0_dp

        ! Asignar segรบn ipar
        select case(ipar)
        case(1)   ! ee: uV vs dV
           q_nsi_ee = (2.0_dp*eps_u + eps_d)*Z_Ge + (eps_u + 2.0_dp*eps_d)*N_Ge
        case(2)   ! eยต: uV vs dV
           q_nsi_emu = (2.0_dp*eps_u + eps_d)*Z_Ge + (eps_u + 2.0_dp*eps_d)*N_Ge
        case(3)   ! eฯ: uV vs dV
           q_nsi_etau = (2.0_dp*eps_u + eps_d)*Z_Ge + (eps_u + 2.0_dp*eps_d)*N_Ge
        case(4)   ! ee^uV vs eยต^uV
           q_nsi_ee  = (2.0_dp*eps_u)*Z_Ge + (eps_u)*N_Ge
           q_nsi_emu = (2.0_dp*eps_d)*Z_Ge + (eps_d)*N_Ge
        case(5)   ! ee^dV vs eยต^dV
           q_nsi_ee  = (eps_u)*Z_Ge + (2.0_dp*eps_u)*N_Ge
           q_nsi_emu = (eps_d)*Z_Ge + (2.0_dp*eps_d)*N_Ge
        case(6)   ! ee^uV vs eยต^dV
           q_nsi_ee  = (2.0_dp*eps_u)*Z_Ge + (eps_u)*N_Ge
           q_nsi_emu = (eps_d)*Z_Ge + (2.0_dp*eps_d)*N_Ge
        end select

        ! Carga efectiva al cuadrado
        qw_sm_val = QW_SM
        q_eff2 = (qw_sm_val + q_nsi_ee)**2 + q_nsi_emu**2 + q_nsi_etau**2

        ! Tasa teรณrica
        R_th(:) = R_unit(:) * q_eff2

        ! Minimizaciรณn analรญtica de ฮฑ
        sum1 = 0.0_dp; sum2 = 0.0_dp
        do bin = 1, nbins
           sum1 = sum1 + (R_exp(bin) * R_th(bin)) / (sigma_exp(bin)**2)
           sum2 = sum2 + (R_th(bin)**2) / (sigma_exp(bin)**2)
        end do
        alpha_best = (sum1 - sum2) / (sum2 + 1.0_dp/sigma_alpha**2)

        ! ฯยฒ con ฮฑ_best
        chi2 = 0.0_dp
        do bin = 1, nbins
           chi2 = chi2 + ((R_exp(bin) - (1.0_dp + alpha_best)*R_th(bin))**2) / (sigma_exp(bin)**2)
        end do
        chi2 = chi2 + (alpha_best / sigma_alpha)**2

        write(u_out, '(3ES15.6)') eps_u, eps_d, chi2
     end do
  end do

  close(u_out)
  write(*,*) 'Archivo generado: ', trim(filename)
  write(*,*) 'Archivo de configuraciรณn: ', trim(configfile)

contains

  subroutine compute_S(Eer, S)
    real(dp), intent(in) :: Eer
    real(dp), intent(out) :: S
    real(dp) :: a, b, T, h, x, sum_trap
    integer :: i
    T = T_from_Eer(Eer)
    if (T <= 0.0_dp) then
       S = 0.0_dp; return
    end if
    a = (T + sqrt(T**2 + 2.0_dp * M_Ge * T)) / 2.0_dp
    if (a >= E_nu_max) then
       S = 0.0_dp; return
    end if
    if (a < E_nu_min_flux) a = E_nu_min_flux
    b = E_nu_max
    h = (b - a) / (npts_nu - 1)
    sum_trap = 0.5_dp * (integrando_S(a, Eer) + integrando_S(b, Eer))
    do i = 2, npts_nu-1
       x = a + (i-1) * h
       sum_trap = sum_trap + integrando_S(x, Eer)
    end do
    S = sum_trap * h
  end subroutine compute_S

  function integrando_S(E_nu, Eer) result(val)
    real(dp), intent(in) :: E_nu, Eer
    real(dp) :: val
    val = flujo_diferencial(E_nu) * dsigma_dEer(E_nu, Eer)
  end function integrando_S

  function integral_trapecio(x, y, z, n) result(intg)
    real(dp), intent(in) :: x(:), y(:), z(:)
    integer, intent(in) :: n
    real(dp) :: intg
    integer :: j
    intg = 0.0_dp
    do j = 1, n-1
       intg = intg + 0.5_dp * (y(j)*z(j) + y(j+1)*z(j+1)) * (x(j+1) - x(j))
    end do
  end function integral_trapecio

end program chi2_nsi_2D
