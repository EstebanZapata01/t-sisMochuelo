!=======================================================================
! Módulo resolution: calcula la matriz de resolución K(i,j) mediante
!   integración numérica de la gaussiana sobre cada bin.
!   No usa la función erf, sino la regla del trapecio.
!=======================================================================
module resolution
  use constants, only: dp, pi, nbins, Erec_min, Erec_width
  implicit none

  ! Define estos parámetros aquí
  real(dp), parameter :: sigma0 = 0.015d-3  ! Ajusta a tus valores
  real(dp), parameter :: eta = 0.0037_dp
  real(dp), parameter :: Fano = 0.13_dp
  integer, parameter :: npts_gauss = 100
contains

  !-------------------------------------------------------------------
  ! sigma_res(Eer): anchura de la resolución [MeV].
  !-------------------------------------------------------------------
  function sigma_res(Eer) result(sig)
    real(dp), intent(in) :: Eer
    real(dp) :: sig
    sig = sqrt(sigma0**2 + Fano * eta * Eer)
  end function sigma_res

  !-------------------------------------------------------------------
  ! compute_resolution_matrix(npts, Emin, Emax, Eer_vals, K_matrix)
  !   Genera una malla de npts puntos de Eer entre Emin y Emax, y para
  !   cada punto calcula la probabilidad de caer en cada bin integrando
  !   numéricamente la gaussiana sobre el intervalo del bin.
  !-------------------------------------------------------------------
  subroutine compute_resolution_matrix(npts, Emin, Emax, Eer_vals, K_matrix)
    integer, intent(in) :: npts
    real(dp), intent(in) :: Emin, Emax
    real(dp), intent(out) :: Eer_vals(npts), K_matrix(npts, nbins)
    real(dp) :: dE, Eer, sig, E_low, E_high, h_g, x, G, sum_trap
    integer :: i, j, k

    dE = (Emax - Emin) / (npts - 1)
    do i = 1, npts
       Eer = Emin + (i-1) * dE
       Eer_vals(i) = Eer
       sig = sigma_res(Eer)
       do j = 1, nbins
          E_low  = Erec_min + (j-1) * Erec_width
          E_high = E_low + Erec_width
          ! Integrar la gaussiana sobre el bin [E_low, E_high] usando regla del trapecio
          h_g = (E_high - E_low) / (npts_gauss - 1)
          sum_trap = 0.0_dp
          do k = 0, npts_gauss-1
             x = E_low + k * h_g
             G = exp(-0.5_dp * ((x - Eer)/sig)**2) / (sqrt(2.0_dp * pi) * sig)
             if (k == 0 .or. k == npts_gauss-1) then
                sum_trap = sum_trap + 0.5_dp * G
             else
                sum_trap = sum_trap + G
             end if
          end do
          K_matrix(i, j) = sum_trap * h_g
       end do
    end do
  end subroutine compute_resolution_matrix

end module resolution
