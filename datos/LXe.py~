#!/usr/bin/env python3
"""
nest_red100_v3.py — Genera Q_y para RED-100 correctamente.
 
Problemas del script anterior:
1. DetectorExample_XENON10 tiene campo interno ~730 V/cm que 
   puede interferir con el drift_field=218 que se pasa.
2. Rango hasta 300 keV innecesario (CEνNS en Xe: 0.05-3 keV).
 
Solución: probar múltiples detectores y verificar Q_y(1keV)~6.2
"""
import nestpy
import nestpy.detectors as dets
import numpy as np, sys
 
print(f"nestpy: {nestpy.__nest_version__}")
print(f"Detectores disponibles: {[d for d in dir(dets) if not d.startswith('_')]}")
print()
 
# ============================================================
# Parámetros NEST correctos para RED-100
# ============================================================
FIELD   = 218.0   # V/cm - campo de deriva RED-100
DENSITY = 2.9     # g/cm3 - LXe a 169 K, 1.29 bar
A_XE    = 131     # masa atómica Xe
Z_XE    = 54      # número atómico Xe
 
# Parámetros NR estándar de NEST (los que usa el paper)
nr_params = [11.0, 1.1, 0.048, -0.0533, 12.6, 0.3, 2.0, 0.3, 2.0, 0.5, 1.0, 1.0]
er_params = [-1.0]*10
 
# Valor de referencia: Q_y(1 keV, 218 V/cm) ≈ 6.2 e/keV (del paper)
REF_QY_1KEV = 6.2
 
def get_qy(nc, T_keV):
    """Obtener Q_y en e/keV usando la API disponible."""
    try:
        y = nc.GetYields(
            interaction  = nestpy.interactions.NR,
            energy       = T_keV,
            density      = DENSITY,
            drift_field  = FIELD,
            A = A_XE, Z = Z_XE,
            nr_parameters = nr_params,
            er_parameters = er_params
        )
        # ElectronYield = número total de e-, dividir por T da e/keV
        return y.ElectronYield / T_keV
    except Exception as e:
        return None
 
# ============================================================
# Probar cada detector disponible y elegir el que da Q_y~6.2
# ============================================================
det_names = [d for d in dir(dets) if not d.startswith('_') and 'Example' in d]
print(f"Detectores de ejemplo: {det_names}")
print()
 
mejor_det  = None
mejor_diff = 999
mejor_qy   = 0
 
for det_name in det_names:
    try:
        det_class = getattr(dets, det_name)
        det       = det_class()
        nc        = nestpy.NESTcalc(det)
        qy        = get_qy(nc, 1.0)
        if qy is not None:
            diff = abs(qy - REF_QY_1KEV)
            print(f"  {det_name}: Q_y(1keV) = {qy:.4f} e/keV  (ref={REF_QY_1KEV}, diff={diff:.3f})")
            if diff < mejor_diff:
                mejor_diff = diff
                mejor_det  = det_name
                mejor_qy   = qy
    except Exception as e:
        print(f"  {det_name}: ERROR - {e}")
 
print()
if mejor_det is None:
    print("ERROR: Ningún detector funcionó.")
    sys.exit(1)
 
print(f"Mejor detector: {mejor_det} -> Q_y(1keV) = {mejor_qy:.4f} e/keV")
if mejor_diff > 1.5:
    print(f"⚠  Diferencia {mejor_diff:.2f} con referencia {REF_QY_1KEV}.")
    print("   El campo del detector puede estar sobreescribiendo 218 V/cm.")
else:
    print(f"✓  Acuerdo con referencia: {mejor_diff:.3f} e/keV")
 
# ============================================================
# Calcular tabla con el mejor detector
# ============================================================
det_class = getattr(dets, mejor_det)
nc = nestpy.NESTcalc(det_class())
 
# Solo el rango relevante para CEνNS en Xe
T_vals = np.linspace(0.05, 5.0, 2000)
Qy_vals = np.zeros(len(T_vals))
 
print(f"\nCalculando {len(T_vals)} puntos de Q_y...")
for i, T in enumerate(T_vals):
    qy = get_qy(nc, T)
    Qy_vals[i] = qy if (qy is not None and qy >= 0) else 0.0
 
# ============================================================
# Guardar
# ============================================================
output = '/home/oem/Desktop/Unipamplona/Trabajo de grado/Códigos/datos/nest_218V_dense.txt'
with open(output, 'w') as f:
    f.write('# Q_y NEST para RED-100 (Xe NR, 218 V/cm, 169 K)\n')
    f.write(f'# Generado con nestpy {nestpy.__nest_version__}\n')
    f.write(f'# Detector usado: {mejor_det}\n')
    f.write('# T_nr[keV]   Qy[e-/keV]\n')
    f.write(f'{len(T_vals)}\n')
    for T, Qy in zip(T_vals, Qy_vals):
        f.write(f'{T:.8f}   {Qy:.8f}\n')
 
print(f"\nArchivo guardado: {output}")
print()
print(f"{'T [keV]':>8} | {'Q_y calculado':>14} | {'Ref paper':>10} | {'OK?':>5}")
print("-"*45)
refs = {0.1:3.5, 0.2:4.8, 0.5:6.0, 1.0:6.2, 1.5:5.8, 2.0:5.3, 3.0:4.5}
for T_c, ref in refs.items():
    idx = np.argmin(np.abs(T_vals - T_c))
    ok  = "✓" if abs(Qy_vals[idx] - ref)/ref < 0.20 else "✗"
    print(f"{T_vals[idx]:>8.2f} | {Qy_vals[idx]:>14.4f} | {ref:>10.1f} | {ok:>5}")
